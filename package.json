{
  "name": "artifact-evidence-skill",
  "version": "0.1.0",
  "description": "Collect local artifacts and command notes into reviewer-ready evidence packets.",
  "type": "module",
  "bin": {
    "artifact-evidence": "./bin/cli.js"
  },
  "scripts": {
    "test": "node --test",
    "check": "node --check src/index.js && node --check bin/cli.js",
    "build": "npm run check",
    "smoke": "node bin/cli.js fixtures/manifest.json",
    "package:smoke": "node scripts/package-smoke.js",
    "release:check": "npm run check && npm test && npm run smoke && npm run package:smoke"
  },
  "files": [
    "bin",
    "docs",
    "fixtures",
    "src",
    "SKILL.md",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CONTRIBUTING.md",
    "CHANGELOG.md"
  ],
  "keywords": [
    "agent-skill",
    "cli",
    "dry-run"
  ],
  "license": "MIT"
}
