{
  "name": "artifact-evidence-skill",
  "version": "0.1.0",
  "description": "Collect local artifacts and command notes into reviewer-ready evidence packets.",
  "type": "module",
  "bin": {
    "artifact-evidence": "./bin/cli.js"
  },
  "scripts": {
    "test": "node --test",
    "check": "node --check src/index.js && node --check bin/cli.js",
    "build": "npm run check",
    "smoke": "node bin/cli.js fixtures/manifest.json",
    "package:smoke": "node scripts/package-smoke.js",
    "release:check": "bash scripts/validate.sh && npm run package:smoke",
    "lint": "npm run check"
  },
  "keywords": [
    "agent-skill",
    "cli",
    "dry-run"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/artifact-evidence-skill.git"
  },
  "files": [
    "bin",
    "src",
    "scripts/package-smoke.js",
    "docs",
    "fixtures",
    "SKILL.md",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CONTRIBUTING.md",
    "CHANGELOG.md"
  ],
  "bugs": {
    "url": "https://github.com/rogerchappel/artifact-evidence-skill/issues"
  },
  "homepage": "https://github.com/rogerchappel/artifact-evidence-skill#readme"
}
